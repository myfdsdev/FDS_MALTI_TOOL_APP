# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Database (MongoDB Atlas) ──────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/multitool?retryWrites=true&w=majority

# ─── JWT Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ──────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Rate Limits ───────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10           # 10 auth attempts per window
RATE_LIMIT_AUTH_WINDOW_MS=900000 # 15 min
RATE_LIMIT_API_MAX=60            # 60 requests per minute per user
RATE_LIMIT_API_WINDOW_MS=60000

# ─── Usage Quotas (free tier) ──────────────────────────────
FREE_PLAN_DAILY_LIMIT=20
FREE_PLAN_MONTHLY_LIMIT=200

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ─── AI Provider (add when ready) ──────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

#──────────────────────────Abmin──────────────────────────
ADMIN_EMAILS=youremail@gmail.com